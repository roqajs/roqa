{
	"name": "rift-elements",
	"version": "0.0.1",
	"description": "Unstyled UI components for Rift",
	"keywords": [
		"UI",
		"framework",
		"rift",
		"rift-js",
		"components",
		"unstyled"
	],
	"homepage": "https://rift.hawkticehurst.com",
	"bugs": {
		"url": "https://github.com/hawkticehurst/rift/issues"
	},
	"license": "MIT",
	"author": "Hawk Ticehurst",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hawkticehurst/rift.git",
		"directory": "packages/rift-elements"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./avatar": {
			"types": "./types/avatar/index.d.ts",
			"import": "./dist/avatar/index.js",
			"default": "./dist/avatar/index.js"
		},
		"./button": {
			"types": "./types/button/index.d.ts",
			"import": "./dist/button/index.js",
			"default": "./dist/button/index.js"
		},
		"./switch": {
			"types": "./types/switch/index.d.ts",
			"import": "./dist/switch/index.js",
			"default": "./dist/switch/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"types"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --project unit",
		"test:browser": "vitest run --project browser",
		"test:coverage": "vitest run --coverage",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"rift-js": "workspace:*"
	},
	"devDependencies": {
		"@babel/generator": "catalog:default",
		"@babel/parser": "catalog:default",
		"@babel/traverse": "catalog:default",
		"@babel/types": "catalog:default",
		"@vitest/browser": "^3.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"magic-string": "catalog:default",
		"playwright": "^1.49.0",
		"rift-vite-plugin": "workspace:*",
		"vite": "npm:rolldown-vite@7.2.5",
		"vitest": "^3.0.0"
	}
}
