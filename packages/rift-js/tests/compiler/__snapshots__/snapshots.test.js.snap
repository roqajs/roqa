// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`compile snapshots > SVG > compiles SVG elements 1`] = `
"
import { bind, defineComponent, svg_template, template } from "rift-js";

const $tmpl_1 = svg_template('<svg width="100" height="100"><circle cx="50" cy="50"></circle></svg>');

function Circle() {
	const radius = { v: 50, e: [] };
	const color = { v: 'blue', e: [] };
	
	this.connected(() => {
    const $root_1 = $tmpl_1();
    this.appendChild($root_1);

    const svg_1 = this.firstChild;
    const circle_1 = svg_1.firstChild;

    circle_1.setAttribute("r", radius.v);
    bind(radius, (v) => {
      circle_1.setAttribute("r", v);
    });
    circle_1.setAttribute("fill", color.v);
    bind(color, (v) => {
      circle_1.setAttribute("fill", v);
    });
  });
}

defineComponent('svg-circle', Circle);
"
`;

exports[`compile snapshots > basic components > compiles component with multiple cells 1`] = `
"
import { bind, defineComponent, delegate, template } from "rift-js";

const $tmpl_1 = template('<form><input><input><button type="submit">Submit</button></form>');

function Form() {
	const name = { v: '', e: [] };
	const email = { v: '', e: [] };
	const submitted = { v: false, e: [] };
	
	this.connected(() => {
    const $root_1 = $tmpl_1();
    this.appendChild($root_1);

    const form_1 = this.firstChild;
    const input_1 = form_1.firstChild;
    const input_2 = input_1.nextSibling;

    input_1.__input = (e) => { name.v = e.target.value; name.ref_1.value = name.v; };
    input_2.__input = (e) => { email.v = e.target.value; email.ref_1.value = email.v; };

    input_1.value = name.v;
    name.ref_1 = input_1;
    input_2.value = email.v;
    email.ref_1 = input_2;
  });
}

defineComponent('my-form', Form);


delegate(["input"]);"
`;

exports[`compile snapshots > basic components > compiles component with reactive state 1`] = `
"
import { bind, defineComponent, delegate, template } from "rift-js";

const $tmpl_1 = template('<div><span> </span><button>+</button></div>');

function Counter() {
	const count = { v: 0, e: [] };
	const increment = () => { count.v = count.v + 1; count.ref_1.nodeValue = "Count: " + count.v; };
	this.connected(() => {
    const $root_1 = $tmpl_1();
    this.appendChild($root_1);

    const div_1 = this.firstChild;
    const span_1 = div_1.firstChild;
    const span_1_text = span_1.firstChild;
    const button_1 = span_1.nextSibling;

    button_1.__click = increment;

    span_1_text.nodeValue = "Count: " + count.v;
    count.ref_1 = span_1_text;
  });
}

defineComponent('my-counter', Counter);


delegate(["click"]);"
`;

