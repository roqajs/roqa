			"types": "./types/index.d.ts",
			"import": "./src/index.js",
			"default": "./src/index.js"
		}
	},
	"dependencies": {
		"roqa": "workspace:*"
	},
	"peerDependencies": {
		"vite": "^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"vite": "catalog:default"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
