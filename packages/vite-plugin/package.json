{
	"name": "@roqajs/vite-plugin",
	"version": "0.0.4",
	"description": "Vite plugin for the Roqa UI framework",
	"keywords": [
		"vite",
		"vite-plugin",
		"roqa",
		"roqajs",
		"web components",
		"custom elements",
		"jsx",
		"compiler"
	],
	"homepage": "https://roqa.dev",
	"bugs": {
		"url": "https://github.com/roqajs/roqa/issues"
	},
	"license": "MIT",
	"author": "Hawk Ticehurst",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/roqajs/roqa.git",
		"directory": "packages/vite-plugin"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "src/index.js",
	"module": "src/index.js",
	"files": [
		"src",
		"types",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"exports": {
